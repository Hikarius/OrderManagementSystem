@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Backoffice Portal - use tabs to access services.</p>

    <ul class="nav nav-tabs" id="serviceTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button" role="tab">Orders</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="catalog-tab" data-bs-toggle="tab" data-bs-target="#catalog" type="button" role="tab">Catalog</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="notification-tab" data-bs-toggle="tab" data-bs-target="#notification" type="button" role="tab">Notification</button>
      </li>
    </ul>

    <div class="tab-content mt-3">
      <div class="tab-pane fade show active" id="orders" role="tabpanel">
        <div class="d-flex gap-2 align-items-center">
            <a id="btnLoadOrders" class="btn btn-sm btn-secondary" href="/Home/GetOrders" data-target="#ordersContent">Load Orders</a>
            <div class="input-group input-group-sm" style="width:260px;">
                <span class="input-group-text">Page</span>
                <input type="number" id="ordersPage" class="form-control" value="1" min="1" />
                <span class="input-group-text">Size</span>
                <input type="number" id="ordersPageSize" class="form-control" value="10" min="1" />
            </div>
            <div class="btn-group btn-group-sm" role="group">
                <button id="ordersPrev" type="button" class="btn btn-outline-secondary">Prev</button>
                <button id="ordersNext" type="button" class="btn btn-outline-secondary">Next</button>
            </div>
            <span id="ordersPageInfo" class="small text-muted"></span>
        </div>
        <div id="ordersContent"></div>

        <div class="mt-3" id="orderActions" style="display:none;">
            <div class="input-group input-group-sm mb-2" style="max-width:520px;margin:0 auto;">
                <span class="input-group-text">Selected Order Id</span>
                <input type="text" class="form-control" id="selectedOrderId" readonly />
                <button id="btnCancelOrder" class="btn btn-outline-danger" type="button">Cancel</button>
            </div>
            <div id="cancelResult" class="small text-muted"></div>
        </div>

        <div class="mt-3" id="orderDetail"></div>

        <hr />
        <h5>Create Order</h5>
        <form id="orderForm">
            <div class="row g-2">
                <div class="col-md-4">
                    <input class="form-control" name="customerEmail" placeholder="Customer Email" />
                </div>
                <div class="col-md-3">
                    <input class="form-control" name="customerTelNumber" placeholder="Customer Phone" />
                </div>
                <div class="col-md-5 text-end">
                    <button id="btnAddItem" type="button" class="btn btn-sm btn-outline-primary">Add Item</button>
                    <button id="btnSubmitOrder" type="button" class="btn btn-sm btn-success">Submit Order</button>
                </div>
            </div>
            <div class="mt-3">
                <table class="table table-bordered table-sm" id="orderItemsTable">
                    <thead>
                        <tr>
                            <th style="width:55%">Product</th>
                            <th style="width:20%">Quantity</th>
                            <th style="width:15%"></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </form>
      </div>
      <div class="tab-pane fade" id="catalog" role="tabpanel">
        <div class="d-flex gap-2 align-items-center">
            <a id="btnLoadProducts" class="btn btn-sm btn-secondary" href="/Home/GetProducts" data-target="#catalogContent">Load Products</a>
            <div class="input-group input-group-sm" style="width:260px;">
                <span class="input-group-text">Page</span>
                <input type="number" id="productsPage" class="form-control" value="1" min="1" />
                <span class="input-group-text">Size</span>
                <input type="number" id="productsPageSize" class="form-control" value="10" min="1" />
            </div>
            <div class="btn-group btn-group-sm" role="group">
                <button id="productsPrev" type="button" class="btn btn-outline-secondary">Prev</button>
                <button id="productsNext" type="button" class="btn btn-outline-secondary">Next</button>
            </div>
            <span id="productsPageInfo" class="small text-muted"></span>
        </div>
        <div id="catalogContent"></div>
        <hr />
        <h5>Product CRUD</h5>
        <form id="productForm" class="row g-2">
            <div class="col-md-3"><input class="form-control" name="name" placeholder="Name" /></div>
            <div class="col-md-3"><input class="form-control" name="description" placeholder="Description" /></div>
            <div class="col-md-2"><input class="form-control" name="price" type="number" step="0.01" placeholder="Price" /></div>
            <div class="col-md-2"><input class="form-control" name="stock" type="number" placeholder="Stock" /></div>
            <div class="col-md-2 d-flex gap-2">
                <button id="btnAddProduct" type="button" class="btn btn-sm btn-success">Add</button>
                <button id="btnUpdateProduct" type="button" class="btn btn-sm btn-primary">Update</button>
                <button id="btnDeleteProduct" type="button" class="btn btn-sm btn-danger">Delete</button>
            </div>
            <input type="hidden" name="id" id="selectedProductId" />
        </form>
      </div>
      <div class="tab-pane fade" id="notification" role="tabpanel">
        <p>
            <a id="btnLoadNotifications" class="btn btn-sm btn-secondary" href="/Home/GetNotifications" data-target="#notificationContent">Load Notifications</a>
        </p>
        <div id="notificationContent"></div>
      </div>
    </div>
</div>

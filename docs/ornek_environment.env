# OrderManagementSystem environment template (.env style)
# Copy the relevant section per service (or use in docker compose via env_file).
# Values here are safe development defaults for running on another machine.

# Global
ASPNETCORE_ENVIRONMENT=Development
REDIS_CONFIGURATION=localhost:6379
JWT_KEY=dev_super_secret_key_please_change_0123456789ABCDEF
JWT_ISSUER=local
RabbitMq__Host=localhost

########################################
# CatalogService
# Use a dedicated database for the catalog schema
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=catalog;Username=postgres;Password=postgres
# No direct upstreams required

########################################
# OrderService
# Use a dedicated database for the order schema
# (set per process/container, same key as above but different DB name)
# If you use this file with docker-compose, keep this under the OrderService service env.
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=orders;Username=postgres;Password=postgres
# Catalog upstream base address used by OrderService for inter-service HTTP calls
CATALOGSERVICE_BASEADDRESS=http://localhost:5173

########################################
# NotificationService
# Use a dedicated database for the notification schema
# (set per process/container, same key as above but different DB name)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=notifications;Username=postgres;Password=postgres

########################################
# BackofficePortal (Razor Pages)
# Points UI to the running services (adjust ports if different on target machine)
ServiceUrls__Order=https://localhost:7122
ServiceUrls__Catalog=https://localhost:7094
ServiceUrls__Notification=https://localhost:7120
# Optionally persist data-protection keys to a folder (uncomment and set a valid path)
# DATA_PROTECTION_KEYS_PATH=C:\\keys\\backoffice-keys

{
  "info": {
    "name": "OrderManagementSystem APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for CatalogService, OrderService, and NotificationService (v1). Uses JWT from OrderService login. Injects X-Correlation-Id via pre-request script."
  },
  "item": [
    {
      "name": "OrderService v1",
      "item": [
        {
          "name": "Auth - Login (sets {{authToken}})",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{orderBaseUrl}}/api/v1/auth/login",
              "host": ["{{orderBaseUrl}}"],
              "path": ["api","v1","auth","login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"pass\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('token');",
                  "  pm.collectionVariables.set('authToken', json.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{orderBaseUrl}}/api/v1/orders",
              "host": ["{{orderBaseUrl}}"],
              "path": ["api","v1","orders"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerEmail\": \"john@example.com\",\n  \"customerTelNumber\": \"+1-555-0100\",\n  \"items\": [\n    { \"productId\": \"{{sampleProductId}}\", \"quantity\": 2 }\n  ],\n  \"idempotencyKey\": \"{{$guid}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{orderBaseUrl}}/api/v1/orders?page=1&pageSize=10",
              "host": ["{{orderBaseUrl}}"],
              "path": ["api","v1","orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Order by Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{orderBaseUrl}}/api/v1/orders/{{sampleOrderId}}",
              "host": ["{{orderBaseUrl}}"],
              "path": ["api","v1","orders","{{sampleOrderId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{orderBaseUrl}}/api/v1/orders/cancel",
              "host": ["{{orderBaseUrl}}"],
              "path": ["api","v1","orders","cancel"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{sampleOrderId}}\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "CatalogService v1",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{catalogBaseUrl}}/api/v1/products?page=1&pageSize=10",
              "host": ["{{catalogBaseUrl}}"],
              "path": ["api","v1","products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product by Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{catalogBaseUrl}}/api/v1/products/{{sampleProductId}}",
              "host": ["{{catalogBaseUrl}}"],
              "path": ["api","v1","products","{{sampleProductId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Add Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{catalogBaseUrl}}/api/v1/products",
              "host": ["{{catalogBaseUrl}}"],
              "path": ["api","v1","products"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Product A\",\n  \"description\": \"Description\",\n  \"price\": 10,\n  \"stock\": 100,\n  \"isActive\": true\n}"
            }
          },
          "response": []
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{catalogBaseUrl}}/api/v1/products",
              "host": ["{{catalogBaseUrl}}"],
              "path": ["api","v1","products"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{sampleProductId}}\",\n  \"name\": \"Product A (Updated)\",\n  \"description\": \"New Desc\",\n  \"price\": 12.5,\n  \"stock\": 90,\n  \"isActive\": true\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{catalogBaseUrl}}/api/v1/products/{{sampleProductId}}",
              "host": ["{{catalogBaseUrl}}"],
              "path": ["api","v1","products","{{sampleProductId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get Products by Id List (batch)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{catalogBaseUrl}}/api/v1/products/batch",
              "host": ["{{catalogBaseUrl}}"],
              "path": ["api","v1","products","batch"]
            },
            "body": {
              "mode": "raw",
              "raw": "[ \n  \"{{sampleProductId}}\", \n  \"00000000-0000-0000-0000-000000000000\" \n]"
            }
          },
          "response": []
        },
        {
          "name": "Decrease Stock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{catalogBaseUrl}}/api/v1/products/decrease",
              "host": ["{{catalogBaseUrl}}"],
              "path": ["api","v1","products","decrease"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [ { \"productId\": \"{{sampleProductId}}\", \"quantity\": 1 } ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Increase Stock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{catalogBaseUrl}}/api/v1/products/increase",
              "host": ["{{catalogBaseUrl}}"],
              "path": ["api","v1","products","increase"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [ { \"productId\": \"{{sampleProductId}}\", \"quantity\": 1 } ]\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "NotificationService v1",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{notificationBaseUrl}}/api/v1/notifications?page=1&pageSize=10",
              "host": ["{{notificationBaseUrl}}"],
              "path": ["api","v1","notifications"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Always inject a fresh correlation id header",
          "const cid = pm.variables.replaceIn('{{$guid}}');",
          "pm.request.headers.upsert({ key: 'X-Correlation-Id', value: cid });"
        ]
      }
    }
  ],
  "variable": [
    { "key": "orderBaseUrl", "value": "https://localhost:5001" },
    { "key": "catalogBaseUrl", "value": "https://localhost:5002" },
    { "key": "notificationBaseUrl", "value": "https://localhost:5003" },
    { "key": "authToken", "value": "" },
    { "key": "sampleProductId", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "sampleOrderId", "value": "22222222-2222-2222-2222-222222222222" }
  ]
}
